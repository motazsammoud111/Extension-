# ═══════════════════════════════════════════════════════════════
# frontend/.env.example — Variables Vite (React)
# Copie en frontend/.env pour le dev local :
#   cp frontend/.env.example frontend/.env
# Pour Vercel : ajoute ces variables dans le dashboard Vercel
# ═══════════════════════════════════════════════════════════════

# URL du backend FastAPI
# Local :
VITE_API_URL=http://localhost:8000
# Production (remplace par ton URL Render) :
# VITE_API_URL=https://digital-twin-backend.onrender.com

# URL du bridge WhatsApp (tourne toujours en LOCAL sur ta machine)
VITE_WA_BRIDGE_URL=http://localhost:3001
