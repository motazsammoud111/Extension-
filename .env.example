# ═══════════════════════════════════════════════════════════════
# Digital Twin AI — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Identité ────────────────────────────────────────────────────
MY_NAME=Motaz                    # Ton prénom (utilisé dans les prompts)

# ── LLM (Groq — gratuit pour les tests) ────────────────────────
# Crée un compte sur https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pour passer à Claude plus tard, commente GROQ_API_KEY et décommente :
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Base de données (Supabase) ──────────────────────────────────
# Crée un projet sur https://supabase.com (gratuit 500 MB)
# Puis : Settings → API → URL & anon key
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# Si SUPABASE_URL est vide → SQLite local utilisé automatiquement

# ── Backend (Render.com ou local) ───────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS : domaines autorisés à appeler le backend (séparer par virgule)
ALLOWED_ORIGINS=http://localhost:5173

# ── WhatsApp Bridge ─────────────────────────────────────────────
WA_BRIDGE_PORT=3001
TWIN_API_URL=http://localhost:8000

# ⚠️  Mode auto-reply — n'active que si tu sais ce que tu fais
WA_AUTO_REPLY=false

# ── Frontend (Vite — fichier frontend/.env) ──────────────────────
# VITE_API_URL=http://localhost:8000
# VITE_API_URL=https://my-twin.onrender.com
# VITE_WA_BRIDGE_URL=http://localhost:3001
