# WhatsApp Bridge — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs

# Port du serveur (Railway le configure automatiquement)
PORT=3001

# URL du backend Digital Twin (sur Render)
TWIN_API_URL=https://digital-twin-backend-9z0t.onrender.com

# Supabase — OBLIGATOIRE pour la persistance cloud
SUPABASE_URL=https://foziumahyiahlrwjzxkb.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Dossier pour les credentials WhatsApp
# Sur Railway : utilise un Volume monté sur /data
AUTH_DIR=/data/.wa_auth
